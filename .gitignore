# ============================================================
# Vivado / Xilinx
# ============================================================
# STRATEGY (2026-06-20): track DESIGN SOURCES, ignore BUILD OUTPUTS.
#   - The deployed BD project lives in vloop_probes2/ (a build dir, ignored below).
#     Its DESIGN (BD: C_DOUT_DEFAULT, core0 CONFIG, VDMA fsync=2, connections) is
#     version-controlled as REGENERATION TCLs in vivado/ (NOT ignored):
#       vivado/vloop_probes2_bd.tcl        (write_bd_tcl -- the block design)
#       vivado/vloop_probes2_recreate.tcl  (write_project_tcl -- the project)
#     Regenerate with: vivado -mode batch -source vivado/vloop_probes2_recreate.tcl
#     Re-export after BD edits with vivado/export_vloop_probes2_tcl.tcl. See REPRODUCE.md.
#   - RTL (rtl/), build/constraint TCLs (vivado/*.tcl), scripts/ are tracked.
#   - Everything below (runs/cache/gen/bit/dcp/logs) is regenerable -> ignored.

# Project build artifacts (any depth under vivado/)
vivado/**/*.runs/
vivado/**/*.cache/
vivado/**/*.hw/
vivado/**/*.ip_user_files/
vivado/**/*.sim/
vivado/**/*.gen/
vivado/**/*.srcs/
vivado/**/*.xpr.bak
vivado/**/vivado_proj/
vivado/.Xil/
.Xil/
vcap*/
vloop*/

# Bitstream and implementation outputs
*.bit
*.bin
*.mcs
*.ltx
*.rpt
*.dcp

# Vivado log / journal
vivado_*.log
vivado_*.jou
*.log
*.jou
hs_err_pid*.dmp

# IP cores (generated, not source)
vivado/**/.gitignore
vivado/**/hdl/
vivado/**/simulation/

